---
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'Monitor de Riesgo del Sistema Financiero Mexicano',
  canonical,
} = Astro.props;

const fullTitle =
  title === 'SFM Monitor' ? title : `${title} · SFM Monitor`;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang={Astro.currentLocale ?? 'es'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
  </head>
  <body class="bg-[--color-sfm-bg] text-[--color-sfm-text] min-h-screen">
    <header class="border-b border-slate-700 px-6 py-4">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href={import.meta.env.BASE_URL} class="text-lg font-semibold">
          SFM Monitor
        </a>
        <nav class="flex gap-4 text-sm">
          <a href="/sfm-monitor/" class="text-slate-400 hover:text-white">
            ← Dashboard legacy
          </a>
          <a
            href="https://github.com/Pamela-ruiz9/sfm-monitor"
            class="text-slate-400 hover:text-white">
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8">
      <slot />
    </main>

    <footer
      class="border-t border-slate-700 px-6 py-6 text-sm text-[--color-sfm-muted]">
      <div class="max-w-6xl mx-auto space-y-1">
        <p>
          Datos de fuentes públicas oficiales (Banxico, CNBV, INEGI). Este
          dashboard NO es producto oficial. No constituye asesoría financiera.
        </p>
        <p>
          Código MIT · Contenido CC-BY 4.0 ·
          <a href="/sfm-monitor/CHANGELOG.md" class="underline">CHANGELOG</a> ·
          <a href="/sfm-monitor/docs/citability.md" class="underline">
            Cómo citar
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
