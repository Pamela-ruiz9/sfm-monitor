---
import { GLOSSARY } from '~/data/glossary';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = GLOSSARY[slug];
---

{entry && (
  <details class="metric-info">
    <summary>
      <span class="summary-label">¿Qué es el {entry.term}?</span>
      <span class="summary-icon" aria-hidden="true">›</span>
    </summary>
    <div class="metric-body">
      {entry.full && (
        <p class="metric-definition">{entry.full}</p>
      )}
      {entry.formula && (
        <div class="metric-row">
          <span class="metric-row-label">Fórmula</span>
          <code class="metric-formula">{entry.formula}</code>
        </div>
      )}
      {entry.threshold && (
        <div class="metric-row">
          <span class="metric-row-label">Referencia</span>
          <span class="metric-threshold">{entry.threshold}</span>
        </div>
      )}
      {entry.source && (
        <div class="metric-row">
          <span class="metric-row-label">Fuente</span>
          <span class="metric-source">{entry.source}</span>
        </div>
      )}
    </div>
  </details>
)}

<style>
  .metric-info {
    border: 1px solid var(--color-border-soft);
    border-radius: 8px;
    overflow: hidden;
    font-size: 12px;
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 8px 14px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--color-text-mute);
    transition: color 0.15s, background 0.15s;
  }

  summary::-webkit-details-marker { display: none; }

  summary:hover {
    color: var(--color-text-dim);
    background: rgba(255,255,255,0.03);
  }

  .summary-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .summary-icon {
    font-size: 14px;
    font-weight: 300;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  details[open] .summary-icon {
    transform: rotate(90deg);
  }

  details[open] summary {
    color: var(--color-text-dim);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .metric-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: rgba(255,255,255,0.015);
  }

  .metric-definition {
    color: var(--color-text-dim);
    line-height: 1.55;
    margin: 0;
  }

  .metric-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 8px;
    align-items: baseline;
  }

  .metric-row-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    padding-top: 1px;
  }

  .metric-formula {
    font-family: var(--font-mono, monospace);
    font-size: 11.5px;
    color: var(--color-gold);
    background: rgba(196, 163, 90, 0.08);
    border: 1px solid rgba(196, 163, 90, 0.2);
    border-radius: 4px;
    padding: 3px 8px;
    line-height: 1.5;
    white-space: normal;
    word-break: break-word;
  }

  .metric-threshold {
    color: var(--color-text-dim);
    line-height: 1.45;
  }

  .metric-source {
    color: var(--color-text-mute);
    font-size: 11px;
    line-height: 1.4;
  }
</style>
