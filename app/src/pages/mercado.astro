---
import Layout from '~/layouts/Layout.astro';
import { datasetJsonLd } from '~/lib/jsonld';
import Header from '~/components/shell/Header.astro';
import TabBar from '~/components/shell/TabBar.astro';
import BottomNav from '~/components/shell/BottomNav.astro';
import Section from '~/components/chrome/Section.astro';
import EditorialHeadline from '~/components/chrome/EditorialHeadline.astro';
import { KpiCard } from '~/components/kpi/KpiCard';
import { FXChart } from '~/components/charts/FXChart';
import { TasaBanxicoChart } from '~/components/charts/TasaBanxicoChart';
import { MercadoDineroChart } from '~/components/charts/MercadoDineroChart';
import { ReservasChart } from '~/components/charts/ReservasChart';
import { ChartDrawer } from '~/components/drawer/ChartDrawer';
import { CmdKPalette } from '~/components/shell/CmdKPalette';
import { UpdateToast } from '~/components/shell/UpdateToast';
import { PWAInstallPrompt } from '~/components/shell/PWAInstallPrompt';
import { OnboardingTour } from '~/components/shell/OnboardingTour';
import { SwipeNav } from '~/components/shell/SwipeNav';
import { PullToRefresh } from '~/components/shell/PullToRefresh';
import { loadSfmData } from '~/data/loader';
import { formatPct } from '~/lib/utils';

const data = loadSfmData();
const m = data.mercado ?? {};

// ─── Tasas de referencia ─────────────────────────────────────────────────────
const tiieActual = m.tiie_fondeo?.actual ?? null;
const tiieHist   = m.tiie_fondeo?.historico ?? [];
const cetesActual = m.cetes_28d?.actual ?? null;
const cetesHist  = m.cetes_28d?.historico ?? [];
const banxicoActual = data.tasa_banxico.actual;
const banxicoHist   = data.tasa_banxico.historico;
const spread = tiieActual != null && cetesActual != null
  ? tiieActual - cetesActual
  : null;

// ─── Reservas internacionales ─────────────────────────────────────────────────
const reservas = m.reservas_internacionales ?? null;
const reservasActualB = reservas?.actual != null ? reservas.actual / 1000 : null; // B USD
const reservasHist    = reservas?.historico ?? [];
// Variación ~4 semanas (5 puntos atrás en histórico semanal)
const reservasVar = (reservasHist.length >= 5 && reservas?.actual != null)
  ? ((reservas.actual - reservasHist[reservasHist.length - 5]!.valor) /
      reservasHist[reservasHist.length - 5]!.valor) * 100
  : null;

// ─── Contexto laboral ─────────────────────────────────────────────────────────
const udi        = m.udis?.actual ?? null;
const udiFecha   = m.udis?.fecha ?? null;
---

<Layout
  title="Mercado"
  description="Mercado de dinero: tipo de cambio, tasas de referencia (TIIE, Cetes, Banxico), reservas internacionales y UDI."
  jsonLd={datasetJsonLd({
    name: 'Mercado de Dinero — México',
    description: 'Tipo de cambio MXN/USD, TIIE Fondeo, Cetes 28d, Tasa Banxico, Reservas Internacionales, UDI. Fuente: Banxico SIE.',
    path: '/mercado',
    keywords: ['tipo de cambio', 'TIIE', 'Cetes', 'Banxico', 'reservas internacionales', 'UDI', 'tasa de interés', 'riesgo de mercado'],
  })}>
  <Header slot="header" />
  <TabBar slot="header" />

  <div class="space-y-6">
    <EditorialHeadline
      eyebrow={`Mercado · ${new Date().toLocaleDateString('es-MX', { year: 'numeric', month: 'long' })}`}
      headline="Tasas interbancarias en convergencia con la política monetaria. Reservas estables en torno a $256B USD."
    />

    <!-- ── KPIs de tasas ── -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {tiieActual != null && (
        <KpiCard
          label="TIIE Fondeo"
          value={formatPct(tiieActual, 4)}
          {...(m.tiie_fondeo?.fecha ? { asOf: m.tiie_fondeo.fecha } : {})}
          iconName="Activity"
          tone="gold"
          indicatorId="tiie"
        />
      )}
      {cetesActual != null && (
        <KpiCard
          label="Cetes 28d"
          value={formatPct(cetesActual, 2)}
          {...(m.cetes_28d?.fecha ? { asOf: m.cetes_28d.fecha } : {})}
          iconName="Percent"
          tone="yellow"
          indicatorId="cetes"
        />
      )}
      <KpiCard
        label="Tasa Banxico"
        value={formatPct(Number(banxicoActual), 2)}
        asOf={data.tasa_banxico.fecha}
        iconName="TrendingDown"
        tone="red"
        indicatorId="tasa"
      />
      {spread != null && (
        <KpiCard
          label="Spread TIIE-Cetes"
          value={formatPct(spread, 4)}
          {...(m.tiie_fondeo?.fecha ? { asOf: m.tiie_fondeo.fecha } : {})}
          iconName="TrendingUp"
          tone={spread > 12 ? 'red' : spread > 10 ? 'yellow' : 'green'}
          indicatorId="spread-tiie-cetes"
        />
      )}
    </div>

    <!-- ── Chart: tasas superpuestas ── -->
    {(tiieHist.length > 0 || cetesHist.length > 0) && (
      <Section
        id="mercado-dinero"
        eyebrow="Tasas de referencia"
        title="TIIE Fondeo · Cetes 28d · Tasa Banxico"
        description="Superposición de las tres tasas de referencia del mercado de dinero mexicano. El spread TIIE-Cetes refleja la tensión interbancaria."
        source="Banco de México, SIE · SF43783 (TIIE Fondeo) · SF43936 (Cetes 28d) · SF61745 (Tasa objetivo)"
        refCode="SF43783"
        tone="gold">
        <MercadoDineroChart
          tiie={tiieHist}
          cetes={cetesHist}
          banxico={banxicoHist}
          client:visible
        />
      </Section>
    )}

    <!-- ── Tipo de cambio (existente) ── -->
    <Section
      id="fx"
      eyebrow="Tipo de cambio"
      title="MXN/USD FIX"
      description="Serie histórica mensual desde 1994."
      source="Banco de México, SIE, serie SF43718"
      refCode="SF43718"
      tone="gold">
      <FXChart series={data.tipo_cambio.historico_mensual} client:visible />
    </Section>

    <!-- ── Reservas internacionales ── -->
    {reservasActualB != null && (
      <>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          <KpiCard
            label="Reservas Internacionales"
            value={`${reservasActualB!.toFixed(1)}B`}
            unit="USD"
            {...(reservas?.fecha ? { asOf: reservas.fecha } : {})}
            iconName="Shield"
            tone="green"
            indicatorId="reservas"
            delta={reservasVar != null ? {
              direction: reservasVar >= 0 ? 'up' : 'down',
              label: `${reservasVar > 0 ? '+' : ''}${reservasVar.toFixed(2)}%`,
              upIsGood: true,
            } : undefined}
          />
          {udi != null && (
            <KpiCard
              label="UDI"
              value={udi.toFixed(6)}
              unit="MXN"
              {...(udiFecha ? { asOf: udiFecha } : {})}
              iconName="DollarSign"
              tone="yellow"
              indicatorId="udi"
            />
          )}
        </div>

        {reservasHist.length > 0 && (
          <Section
            id="reservas"
            eyebrow="Reservas internacionales"
            title="Evolución semanal — últimas 52 semanas"
            description="Activos internacionales del Banco de México. Cushion contra choques externos y señal de confianza en el peso."
            source="Banco de México, SIE, serie SF43707"
            refCode="SF43707"
            tone="green">
            <ReservasChart series={reservasHist} client:visible />
          </Section>
        )}
      </>
    )}

    <!-- ── Tasa Banxico histórica ── -->
    <Section
      id="tasa"
      eyebrow="Política monetaria"
      title="Tasa objetivo Banxico"
      description="Decisiones de política monetaria — stepped, mantiene hasta la siguiente reunión."
      source="Banco de México, SIE, serie SF61745"
      refCode="SF61745"
      tone="red">
      <TasaBanxicoChart series={banxicoHist} client:visible />
    </Section>
  </div>

  <ChartDrawer slot="drawer" client:idle />
  <CmdKPalette slot="cmdk" client:idle />
  <UpdateToast slot="update-toast" client:idle />
  <PWAInstallPrompt slot="install-prompt" client:idle />
  <OnboardingTour slot="onboarding" client:idle />
  <SwipeNav slot="gestures" client:idle />
  <PullToRefresh slot="gestures" client:idle />
  <BottomNav slot="bottom-nav" />
</Layout>
