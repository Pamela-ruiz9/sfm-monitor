---
import Layout from '~/layouts/Layout.astro';
import { catalogJsonLd } from '~/lib/jsonld';
import Header from '~/components/shell/Header.astro';
import TabBar from '~/components/shell/TabBar.astro';
import BottomNav from '~/components/shell/BottomNav.astro';
import HeroScore from '~/components/HeroScore.astro';
import AlertsPanel from '~/components/alerts/AlertsPanel.astro';
import { KpiCard } from '~/components/kpi/KpiCard';
import { ActiveIndicatorChart } from '~/components/charts/ActiveIndicatorChart';
import { ChartDrawer } from '~/components/drawer/ChartDrawer';
import { CmdKPalette } from '~/components/shell/CmdKPalette';
import { UpdateToast } from '~/components/shell/UpdateToast';
import { PWAInstallPrompt } from '~/components/shell/PWAInstallPrompt';
import { OnboardingTour } from '~/components/shell/OnboardingTour';
import { SwipeNav } from '~/components/shell/SwipeNav';
import { PullToRefresh } from '~/components/shell/PullToRefresh';
import { loadSfmData } from '~/data/loader';
import { computeDelta, formatMxn, formatPct } from '~/lib/utils';

const data = loadSfmData();
const m = data.mercado ?? {};

// ─── Tipo de cambio ────────────────────────────────────────────────────────────
const fxLatest = Number(data.tipo_cambio.actual);
const fxDelta = computeDelta(data.tipo_cambio.historico_mensual.map((p) => p.valor));

// ─── Tasa Banxico ──────────────────────────────────────────────────────────────
const tasaLatest = Number(data.tasa_banxico.actual);
const tasaDelta = computeDelta(data.tasa_banxico.historico.map((p) => p.valor));

// ─── Inflación ─────────────────────────────────────────────────────────────────
const inflacionLatest = Number(data.inflacion.actual);
const inflacionDelta = computeDelta(data.inflacion.historico_mensual.map((p) => p.valor));

// ─── Mercado de dinero ─────────────────────────────────────────────────────────
const tiieActual     = m.tiie_fondeo?.actual ?? null;
const tiieFecha      = m.tiie_fondeo?.fecha ?? null;
const tiieHist       = m.tiie_fondeo?.historico ?? [];
const cetesActual    = m.cetes_28d?.actual ?? null;
const cetesFecha     = m.cetes_28d?.fecha ?? null;
const cetesHist      = m.cetes_28d?.historico ?? [];
const spread         = tiieActual != null && cetesActual != null ? tiieActual - cetesActual : null;

// ─── Reservas internacionales ──────────────────────────────────────────────────
const reservas       = m.reservas_internacionales ?? null;
const reservasActual = reservas?.actual ?? null;
const reservasB      = reservasActual != null ? reservasActual / 1000 : null;
const reservasFecha  = reservas?.fecha ?? null;
const reservasHist   = reservas?.historico ?? [];
const reservasVar    = (reservasHist.length >= 5 && reservasActual != null)
  ? ((reservasActual - reservasHist[reservasHist.length - 5]!.valor) /
      reservasHist[reservasHist.length - 5]!.valor) * 100
  : null;

// ─── UDI ───────────────────────────────────────────────────────────────────────
const udi      = m.udis?.actual ?? null;
const udiFecha = m.udis?.fecha ?? null;
---

<Layout
  title="SFM Monitor"
  description="Resumen ejecutivo del riesgo del Sistema Financiero Mexicano. Tipo de cambio, tasas, inflación y reservas internacionales. Datos de Banxico SIE, CNBV e INEGI."
  jsonLd={catalogJsonLd()}>
  <Header slot="header" />
  <TabBar slot="header" />

  <div class="space-y-8">
    <HeroScore />

    <!-- KPI grid — click any card to update the chart below -->
    <div
      id="kpi-grid"
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-3 lg:gap-4">
      <KpiCard
        label="MXN/USD FIX"
        value={formatMxn(fxLatest, 4)}
        asOf={data.tipo_cambio.fecha}
        iconName="DollarSign"
        tone="gold"
        indicatorId="fx"
        delta={fxDelta && {
          direction: fxDelta.direction,
          label: `${fxDelta.abs > 0 ? '+' : ''}${fxDelta.abs.toFixed(4)}`,
          upIsGood: false,
        }}
      />
      <KpiCard
        label="Tasa Banxico"
        value={formatPct(tasaLatest, 2)}
        asOf={data.tasa_banxico.fecha}
        iconName="Percent"
        tone="red"
        indicatorId="tasa"
        delta={tasaDelta && {
          direction: tasaDelta.direction,
          label: `${tasaDelta.abs > 0 ? '+' : ''}${tasaDelta.abs.toFixed(2)} pp`,
          upIsGood: false,
        }}
      />
      <KpiCard
        label="Inflación anual"
        value={formatPct(inflacionLatest, 2)}
        asOf={data.inflacion.fecha}
        iconName="TrendingUp"
        tone="yellow"
        indicatorId="inflacion"
        delta={inflacionDelta && {
          direction: inflacionDelta.direction,
          label: `${inflacionDelta.abs > 0 ? '+' : ''}${inflacionDelta.abs.toFixed(2)} pp`,
          upIsGood: false,
        }}
      />
      {tiieActual != null && (
        <KpiCard
          label="TIIE Fondeo"
          value={formatPct(tiieActual, 4)}
          {...(tiieFecha ? { asOf: tiieFecha } : {})}
          iconName="Activity"
          tone="gold"
          indicatorId="tiie"
        />
      )}
      {cetesActual != null && (
        <KpiCard
          label="Cetes 28d"
          value={formatPct(cetesActual, 2)}
          {...(cetesFecha ? { asOf: cetesFecha } : {})}
          iconName="Percent"
          tone="yellow"
          indicatorId="cetes"
        />
      )}
      {spread != null && (
        <KpiCard
          label="Spread TIIE-Cetes"
          value={formatPct(spread, 4)}
          {...(tiieFecha ? { asOf: tiieFecha } : {})}
          iconName="TrendingUp"
          tone={spread > 12 ? 'red' : spread > 10 ? 'yellow' : 'green'}
          indicatorId="spread-tiie-cetes"
        />
      )}
      {reservasB != null && (
        <KpiCard
          label="Reservas Int."
          value={`${reservasB.toFixed(1)}B`}
          unit="USD"
          {...(reservasFecha ? { asOf: reservasFecha } : {})}
          iconName="Shield"
          tone="green"
          indicatorId="reservas"
          delta={reservasVar != null ? {
            direction: reservasVar >= 0 ? 'up' : 'down',
            label: `${reservasVar > 0 ? '+' : ''}${reservasVar.toFixed(2)}%`,
            upIsGood: true,
          } : undefined}
        />
      )}
      {udi != null && (
        <KpiCard
          label="UDI"
          value={udi.toFixed(4)}
          unit="MXN"
          {...(udiFecha ? { asOf: udiFecha } : {})}
          iconName="DollarSign"
          tone="yellow"
        />
      )}
      <KpiCard
        label="IMOR Banca"
        value="2.2%"
        asOf={data.credito.imor.fecha}
        iconName="BarChart2"
        tone="green"
      />
    </div>

    <!-- Active indicator chart + alerts -->
    <div class="grid lg:grid-cols-3 gap-4 items-start">
      <div class="lg:col-span-2">
        <ActiveIndicatorChart
          fxSeries={data.tipo_cambio.historico_mensual}
          tasaSeries={data.tasa_banxico.historico}
          inflacionSeries={data.inflacion.historico_mensual}
          tiieHist={tiieHist}
          cetesHist={cetesHist}
          banxicoHist={data.tasa_banxico.historico}
          reservasHist={reservasHist}
          client:load
        />
      </div>
      <div>
        <AlertsPanel />
      </div>
    </div>
  </div>

  <ChartDrawer slot="drawer" client:idle />
  <CmdKPalette slot="cmdk" client:idle />
  <UpdateToast slot="update-toast" client:idle />
  <PWAInstallPrompt slot="install-prompt" client:idle />
  <OnboardingTour slot="onboarding" client:idle />
  <SwipeNav slot="gestures" client:idle />
  <PullToRefresh slot="gestures" client:idle />
  <BottomNav slot="bottom-nav" />
</Layout>

<style is:global>
  /* Highlight the active KPI card */
  #kpi-grid [data-kpi-active] {
    border-color: var(--color-gold);
    transform: translateY(-1px);
  }
</style>

<script>
  const CHART_IDS = new Set([
    'fx', 'tasa', 'inflacion', 'tiie', 'cetes', 'spread-tiie-cetes', 'reservas',
  ]);

  function getIndicatorFromUrl(): string {
    return new URLSearchParams(window.location.search).get('indicator') ?? 'fx';
  }

  function setActiveKpi(indicatorId: string) {
    document.querySelectorAll<HTMLElement>('#kpi-grid [data-drawer-trigger]').forEach((el) => {
      el.removeAttribute('data-kpi-active');
    });
    const el = document.querySelector<HTMLElement>(
      `#kpi-grid [data-drawer-trigger="${indicatorId}"]`,
    );
    if (el) el.setAttribute('data-kpi-active', 'true');
  }

  function handleKpiClick(e: MouseEvent) {
    const anchor = (e.target as Element).closest<HTMLElement>('#kpi-grid [data-drawer-trigger]');
    if (!anchor) return;
    const indicatorId = anchor.dataset.drawerTrigger ?? '';
    if (!CHART_IDS.has(indicatorId)) return;
    // Prevent Astro ClientRouter from navigating + stop drawer from opening
    e.preventDefault();
    e.stopImmediatePropagation();
    history.pushState({}, '', `?indicator=${indicatorId}`);
    document.dispatchEvent(
      new CustomEvent('sfm:kpi-select', { detail: { indicatorId } }),
    );
    setActiveKpi(indicatorId);
  }

  function setup() {
    setActiveKpi(getIndicatorFromUrl());
    // capture:true so this runs before Astro's ClientRouter bubble listener
    document.removeEventListener('click', handleKpiClick, true);
    document.addEventListener('click', handleKpiClick, true);
  }

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
