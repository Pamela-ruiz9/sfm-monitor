---
import Layout from '~/layouts/Layout.astro';
import { DataFreshnessBadge } from '~/components/DataFreshnessBadge';
import { FXChart } from '~/components/charts/FXChart';
import { loadSfmData } from '~/data/loader';

const data = loadSfmData();
const fxSeries = data.tipo_cambio.historico_mensual;
const fxLatest = Number(data.tipo_cambio.actual).toFixed(4);
const fxLatestMonth = data.tipo_cambio.fecha;
---

<Layout
  title="SFM Monitor"
  description="Dashboard público de riesgo del Sistema Financiero Mexicano. Datos de Banxico, CNBV e INEGI.">
  <section class="space-y-6">
    <header class="space-y-2">
      <div class="inline-block px-2 py-0.5 text-xs bg-amber-900/40 text-amber-300 rounded">
        Vista preview · v0.2.0-dev · migración Astro en curso
      </div>
      <h1 class="text-3xl font-bold">SFM Monitor — preview Astro</h1>
      <p class="text-[--color-sfm-muted]">
        Versión beta de la migración a Astro 5 + React 19 + TypeScript strict.
        El dashboard estable sigue en
        <a href="/sfm-monitor/" class="underline">
          /sfm-monitor/
        </a>.
      </p>
      <DataFreshnessBadge
        source="Banxico SIE"
        lastUpdated={data.ultima_actualizacion}
        client:load
      />
    </header>

    <article class="space-y-3">
      <div class="flex items-baseline justify-between">
        <h2 class="text-xl font-semibold">Tipo de cambio MXN/USD (FIX)</h2>
        <div class="text-right">
          <div class="text-3xl font-mono tabular">${fxLatest}</div>
          <div class="text-xs text-[--color-sfm-muted]">{fxLatestMonth}</div>
        </div>
      </div>
      <p class="text-sm text-[--color-sfm-muted]">
        Serie histórica mensual desde 1994. Fuente: Banco de México, SIE,
        serie SF43718. Bandas verticales: crisis Tequila (1994-95), Gran
        Crisis Financiera (2008-09), COVID-19 (2020).
      </p>
      <FXChart series={fxSeries} client:visible />
    </article>

    <article class="border-t border-slate-700 pt-6 space-y-2">
      <h2 class="text-lg font-semibold">Próximas charts a migrar</h2>
      <ul class="text-sm text-[--color-sfm-muted] list-disc list-inside space-y-1">
        <li>Tasa objetivo Banxico + TIIE 28d</li>
        <li>Inflación INPC anual vs objetivo 3% ±1%</li>
        <li>IMOR Banca Múltiple histórico</li>
        <li>IMOR por segmento (comercial/consumo/vivienda/tarjeta)</li>
        <li>IMOR por banco G-7</li>
        <li>IFRS 9 stages 1/2/3</li>
        <li>SoFiPOs IMOR top 15</li>
        <li>SoFiPOs IMORA + ROA</li>
      </ul>
      <p class="text-xs text-[--color-sfm-muted]">
        Ver
        <a
          href="https://github.com/Pamela-ruiz9/sfm-monitor/blob/main/docs/migration-astro.md"
          class="underline">
          docs/migration-astro.md
        </a>
        para el plan completo.
      </p>
    </article>
  </section>
</Layout>
