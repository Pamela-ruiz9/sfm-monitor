---
import Layout from '~/layouts/Layout.astro';
import { catalogJsonLd } from '~/lib/jsonld';
import Header from '~/components/shell/Header.astro';
import TabBar from '~/components/shell/TabBar.astro';
import BottomNav from '~/components/shell/BottomNav.astro';
import HeroScore from '~/components/HeroScore.astro';
import Section from '~/components/chrome/Section.astro';
import AlertsPanel from '~/components/alerts/AlertsPanel.astro';
import { KpiCard } from '~/components/kpi/KpiCard';
import { FXChart } from '~/components/charts/FXChart';
import { loadSfmData } from '~/data/loader';
import { computeDelta, formatMxn, formatPct } from '~/lib/utils';

import { ChartDrawer } from '~/components/drawer/ChartDrawer';
import { CmdKPalette } from '~/components/shell/CmdKPalette';
import { UpdateToast } from '~/components/shell/UpdateToast';
import { PWAInstallPrompt } from '~/components/shell/PWAInstallPrompt';
import { OnboardingTour } from '~/components/shell/OnboardingTour';
import { SwipeNav } from '~/components/shell/SwipeNav';
import { PullToRefresh } from '~/components/shell/PullToRefresh';

const data = loadSfmData();

const fxLatest = Number(data.tipo_cambio.actual);
const fxDelta = computeDelta(
  data.tipo_cambio.historico_mensual.map((p) => p.valor),
);

const tasaLatest = Number(data.tasa_banxico.actual);
const tasaDelta = computeDelta(
  data.tasa_banxico.historico.map((p) => p.valor),
);

const inflacionLatest = Number(data.inflacion.actual);
const inflacionDelta = computeDelta(
  data.inflacion.historico_mensual.map((p) => p.valor),
);

const imorPlaceholder = 2.2;

// ─── Mercado (Reservas + TIIE) ────────────────────────────────────────────────
const mercado = data.mercado ?? {};
const reservasActual = mercado.reservas_internacionales?.actual ?? null;
const reservasB = reservasActual != null ? reservasActual / 1000 : null;
const reservasFecha = mercado.reservas_internacionales?.fecha ?? null;
const reservasHist = mercado.reservas_internacionales?.historico ?? [];
const reservasVar = (reservasHist.length >= 5 && reservasActual != null)
  ? ((reservasActual - reservasHist[reservasHist.length - 5]!.valor) /
      reservasHist[reservasHist.length - 5]!.valor) * 100
  : null;

const tiieActual = mercado.tiie_fondeo?.actual ?? null;
const tiieFecha  = mercado.tiie_fondeo?.fecha ?? null;
---

<Layout
  title="SFM Monitor"
  description="Resumen ejecutivo del riesgo del Sistema Financiero Mexicano. Datos de Banxico SIE, CNBV e INEGI."
  jsonLd={catalogJsonLd()}>
  <Header slot="header" />
  <TabBar slot="header" />

  <div class="space-y-8">
    <HeroScore />

    <!-- KPI grid — 4 cols mobile-2, desktop up to 6 when mercado data available -->
    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3 lg:gap-4">
      <KpiCard
        label="MXN/USD FIX"
        value={formatMxn(fxLatest, 4)}
        asOf={data.tipo_cambio.fecha}
        iconName="DollarSign"
        tone="gold"
        indicatorId="fx"
        delta={fxDelta && {
          direction: fxDelta.direction,
          label: `${fxDelta.abs > 0 ? '+' : ''}${fxDelta.abs.toFixed(4)}`,
          upIsGood: false,
        }}
      />
      <KpiCard
        label="Tasa Banxico"
        value={formatPct(tasaLatest, 2)}
        asOf={data.tasa_banxico.fecha}
        iconName="Percent"
        tone="red"
        indicatorId="tasa"
        delta={tasaDelta && {
          direction: tasaDelta.direction,
          label: `${tasaDelta.abs > 0 ? '+' : ''}${tasaDelta.abs.toFixed(2)} pp`,
          upIsGood: false,
        }}
      />
      <KpiCard
        label="Inflación anual"
        value={formatPct(inflacionLatest, 2)}
        asOf={data.inflacion.fecha}
        iconName="TrendingUp"
        tone="yellow"
        indicatorId="inflacion"
        delta={inflacionDelta && {
          direction: inflacionDelta.direction,
          label: `${inflacionDelta.abs > 0 ? '+' : ''}${inflacionDelta.abs.toFixed(2)} pp`,
          upIsGood: false,
        }}
      />
      <KpiCard
        label="IMOR Banca"
        value={formatPct(imorPlaceholder, 2)}
        asOf="placeholder · CNBV pendiente"
        iconName="Activity"
        tone="green"
        indicatorId="imor"
      />
      {reservasB != null && (
        <KpiCard
          label="Reservas Internacionales"
          value={`${reservasB.toFixed(1)}B`}
          unit="USD"
          {...(reservasFecha ? { asOf: reservasFecha } : {})}
          iconName="Shield"
          tone="green"
          indicatorId="reservas"
          delta={reservasVar != null ? {
            direction: reservasVar >= 0 ? 'up' : 'down',
            label: `${reservasVar > 0 ? '+' : ''}${reservasVar.toFixed(2)}%`,
            upIsGood: true,
          } : undefined}
        />
      )}
      {tiieActual != null && (
        <KpiCard
          label="TIIE Fondeo"
          value={formatPct(tiieActual, 4)}
          {...(tiieFecha ? { asOf: tiieFecha } : {})}
          iconName="Activity"
          tone="gold"
          indicatorId="tiie"
        />
      )}
    </div>

    <!-- Featured chart + alerts -->
    <div class="grid lg:grid-cols-3 gap-4 items-stretch">
      <div class="lg:col-span-2">
        <Section
          eyebrow="Riesgo de mercado"
          title="Tipo de cambio MXN/USD · histórico"
          description="Serie mensual desde 1994. Bandas verticales: crisis Tequila (1994-95), Gran Crisis Financiera (2008-09), COVID-19 (2020)."
          source="Banco de México, SIE, serie SF43718"
          refCode="SF43718"
          tone="gold">
          <FXChart series={data.tipo_cambio.historico_mensual} client:visible />
        </Section>
      </div>
      <div>
        <AlertsPanel />
      </div>
    </div>

    <!-- Liquidez section -->
    <Section
      id="liquidez"
      eyebrow="Liquidez del sistema"
      title="Depósitos y razón de liquidez"
      description="Crecimiento anual de la base de depósitos del sistema bancario mexicano. Métrica complementaria al riesgo de crédito."
      source="CNBV — Boletín Estadístico de Banca Múltiple (datos pendientes en pipeline)"
      tone="green">
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="text-center py-6">
          <div class="text-[10px] font-medium uppercase tracking-wider text-[--color-text-mute] mb-2">
            Crecimiento anual depósitos
          </div>
          <div class="serif tabular text-4xl font-semibold text-[--color-green]">
            +7.2<span class="text-lg text-[--color-text-dim]">%</span>
          </div>
          <div class="text-[10px] text-[--color-text-mute] mt-1">
            Estimado · pipeline CNBV pendiente
          </div>
        </div>
        <div class="text-center py-6">
          <div class="text-[10px] font-medium uppercase tracking-wider text-[--color-text-mute] mb-2">
            LCR (Liquidity Coverage Ratio)
          </div>
          <div class="serif tabular text-4xl font-semibold text-[--color-green]">
            331<span class="text-lg text-[--color-text-dim]">%</span>
          </div>
          <div class="text-[10px] text-[--color-text-mute] mt-1">
            Mediana 2T 2025 (vs mín. regulatorio 100%)
          </div>
        </div>
      </div>
    </Section>
  </div>

  <ChartDrawer slot="drawer" client:idle />
  <CmdKPalette slot="cmdk" client:idle />
  <UpdateToast slot="update-toast" client:idle />
  <PWAInstallPrompt slot="install-prompt" client:idle />
  <OnboardingTour slot="onboarding" client:idle />
  <SwipeNav slot="gestures" client:idle />
  <PullToRefresh slot="gestures" client:idle />
  <BottomNav slot="bottom-nav" />
</Layout>
