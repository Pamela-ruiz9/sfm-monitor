{
  "name": "sfm-monitor-app",
  "version": "0.2.0-dev.1",
  "description": "Astro 5 + React 19 + TypeScript strict frontend for SFM Monitor — app-like redesign + PWA targeting custom domain",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview --host",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.astro",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,md,mdx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.4.0",
    "@astrojs/sitemap": "^3.6.0",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^5.16.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "echarts": "^6.0.0",
    "lucide-react": "^1.11.0",
    "nanostores": "^1.0.1",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.7.3",
    "vaul": "^1.1.2",
    "workbox-window": "^7.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
